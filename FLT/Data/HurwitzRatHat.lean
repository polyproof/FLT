import FLT.Data.Hurwitz
import FLT.Data.QHat

open scoped TensorProduct

/-- The base change of the Hurwitz quaternions to ZHat. -/
noncomputable def HurwitzHat : Type := рқ“һ вҠ—[в„Ө] ZHat

namespace HurwitzHat

/-- The base change of the Hurwitz quaternions to ZHat. -/
scoped notation "рқ“һ^" => HurwitzHat

noncomputable instance : Ring рқ“һ^ := Algebra.TensorProduct.instRing

/-- The map `рқ“һ вҶ’ рқ“һ^` sending `y` to `y вҠ—вӮң 1` is surjective modulo `N`.
That is, every element of `рқ“һ вҠ—[в„Ө] ZHat` is congruent to an element of `рқ“һ` modulo `N`. -/
lemma surjective_pnat_quotient (N : в„•+) (z : рқ“һ вҠ—[в„Ө] ZHat) :
    вҲғ (y : рқ“һ) (w : рқ“һ вҠ—[в„Ө] ZHat), z = y вҠ—вӮң[в„Ө] 1 + (N : в„Ө) вҖў w := by
  induction z using TensorProduct.induction_on with
  | zero => exact вҹЁ0, 0, by simpвҹ©
  | tmul a wвӮҖ =>
    obtain вҹЁq, r, hqr, _вҹ© := ZHat.nat_dense N wвӮҖ
    refine вҹЁ(r : в„Ө) вҖў a, a вҠ—вӮң[в„Ө] q, ?_вҹ©
    rw [hqr, TensorProduct.tmul_add]
    have h1 : a вҠ—вӮң[в„Ө] ((r : в„•) : ZHat) = ((r : в„Ө) вҖў a) вҠ—вӮң[в„Ө] (1 : ZHat) := by
      have : ((r : в„•) : ZHat) = (r : в„Ө) вҖў (1 : ZHat) := by
        rw [zsmul_eq_mul, mul_one]; push_cast; rfl
      rw [this, TensorProduct.tmul_smul, TensorProduct.smul_tmul']
    have h2 : a вҠ—вӮң[в„Ө] ((N : в„•) * q : ZHat) = (N : в„Ө) вҖў (a вҠ—вӮң[в„Ө] q) := by
      have : ((N : в„•) * q : ZHat) = (N : в„Ө) вҖў q := by
        rw [zsmul_eq_mul]; push_cast; rfl
      rw [this, TensorProduct.tmul_smul]
    rw [h1, h2]
    abel
  | add x y hx hy =>
    obtain вҹЁyвӮҒ, wвӮҒ, hxвҹ© := hx
    obtain вҹЁyвӮӮ, wвӮӮ, hyвҹ© := hy
    refine вҹЁyвӮҒ + yвӮӮ, wвӮҒ + wвӮӮ, ?_вҹ©
    rw [hx, hy, TensorProduct.add_tmul, smul_add]
    abel

end HurwitzHat

/-- The quaternion algebra в„ҡ + в„ҡi + в„ҡj + в„ҡk. -/
noncomputable def HurwitzRat : Type := в„ҡ вҠ—[в„Ө] рқ“һ

namespace HurwitzRat

/-- The quaternion algebra в„ҡ + в„ҡi + в„ҡj + в„ҡk. -/
scoped notation "D" => HurwitzRat

noncomputable instance : Ring D := Algebra.TensorProduct.instRing

end HurwitzRat

open scoped HurwitzRat HurwitzHat

/-- The "profinite Hurwitz quaternions" over the finite adeles of в„ҡ; a free rank 4 module
generated by 1, i, j, and (1+i+j+k)/2. -/
noncomputable def HurwitzRatHat : Type := D вҠ—[в„Ө] ZHat

namespace HurwitzRatHat

/-- The "profinite Hurwitz quaternions" over the finite adeles of в„ҡ; a free rank 4 module
generated by 1, i, j, and (1+i+j+k)/2. -/
scoped notation "D^" => HurwitzRatHat

noncomputable instance : Ring D^ := Algebra.TensorProduct.instRing

/-- The inclusion from D=в„ҡ+в„ҡi+в„ҡj+в„ҡk to D вҠ— рқ”ё, with рқ”ё the finite adeles of в„ҡ. -/
noncomputable abbrev jвӮҒ : D вҶ’вӮҗ[в„Ө] D^ := Algebra.TensorProduct.includeLeft
-- (Algebra.TensorProduct.assoc в„Ө в„ҡ рқ“һ ZHat).symm.trans Algebra.TensorProduct.includeLeft

lemma injective_hRat :
    Function.Injective jвӮҒ := by
  haveI : NoZeroDivisors рқ“һ := вҹЁfun {a b} hab => by
    have hn : Hurwitz.norm a * Hurwitz.norm b = 0 := by
      rw [вҶҗ Hurwitz.norm_mul]; exact (Hurwitz.norm_eq_zero _).mpr hab
    rcases mul_eq_zero.mp hn with h | h
    В· exact Or.inl ((Hurwitz.norm_eq_zero _).mp h)
    В· exact Or.inr ((Hurwitz.norm_eq_zero _).mp h)вҹ©
  haveI : IsDomain рқ“һ := NoZeroDivisors.to_isDomain _
  haveI : IsAddTorsionFree рқ“һ := IsDomain.instIsAddTorsionFreeOfCharZero _
  haveI : Module.Flat в„Ө рқ“һ := by
    rw [IsDedekindDomain.flat_iff_torsion_eq_bot]
    exact Submodule.isTorsionFree_iff_torsion_eq_bot.mp inferInstance
  haveI : Module.Flat в„Ө в„ҡ := IsLocalization.flat в„ҡ (nonZeroDivisors в„Ө)
  haveI : Module.Flat в„Ө D := by
    change Module.Flat в„Ө (в„ҡ вҠ—[в„Ө] рқ“һ)
    infer_instance
  exact Algebra.TensorProduct.includeLeft_injective (Int.cast_injective (Оұ := ZHat))

/-- The inclusion from the profinite Hurwitz quaternions to to рқ”ё+рқ”ёi+рқ”ёj+рқ”ёk,
with рқ”ё the finite adeles of в„ҡ. -/
noncomputable abbrev jвӮӮ : рқ“һ^ вҶ’вӮҗ[в„Ө] D^ :=
  ((Algebra.TensorProduct.assoc в„Ө в„Ө в„Ө в„ҡ рқ“һ ZHat).symm : в„ҡ вҠ— рқ“һ^ вүғвӮҗ[в„Ө] D вҠ— ZHat).toAlgHom.comp
  (Algebra.TensorProduct.includeRight : рқ“һ^ вҶ’вӮҗ[в„Ө] в„ҡ вҠ— рқ“һ^)

lemma injective_zHat :
    Function.Injective jвӮӮ := by
  haveI : NoZeroDivisors рқ“һ := вҹЁfun {a b} hab => by
    have hn : Hurwitz.norm a * Hurwitz.norm b = 0 := by
      rw [вҶҗ Hurwitz.norm_mul]; exact (Hurwitz.norm_eq_zero _).mpr hab
    rcases mul_eq_zero.mp hn with h | h
    В· exact Or.inl ((Hurwitz.norm_eq_zero _).mp h)
    В· exact Or.inr ((Hurwitz.norm_eq_zero _).mp h)вҹ©
  haveI : IsDomain рқ“һ := NoZeroDivisors.to_isDomain _
  haveI : IsAddTorsionFree рқ“һ := IsDomain.instIsAddTorsionFreeOfCharZero _
  haveI : Module.Flat в„Ө рқ“һ := by
    rw [IsDedekindDomain.flat_iff_torsion_eq_bot]
    exact Submodule.isTorsionFree_iff_torsion_eq_bot.mp inferInstance
  haveI : Module.Flat в„Ө рқ“һ^ := by
    change Module.Flat в„Ө (рқ“һ вҠ—[в„Ө] ZHat)
    infer_instance
  intro x y hxy
  have := (AlgEquiv.injective
    (Algebra.TensorProduct.assoc в„Ө в„Ө в„Ө в„ҡ рқ“һ ZHat).symm) hxy
  exact Algebra.TensorProduct.includeRight_injective (Int.cast_injective (Оұ := в„ҡ)) this

-- should I rearrange tensors? Not sure if D^ should be (в„ҡ вҠ— рқ“һ) вҠ— в„Өhat or в„ҡ вҠ— (рқ“һ вҠ— Zhat)
lemma canonicalForm (z : D^) : вҲғ (N : в„•+) (z' : рқ“һ^), z = jвӮҒ ((NвҒ»В№ : в„ҡ) вҠ—вӮң 1 : D) * jвӮӮ z' := by
  suffices h : вҲҖ (w : в„ҡ вҠ—[в„Ө] рқ“һ^), вҲғ (N : в„•+) (z' : рқ“һ^), w = (1 / N : в„ҡ) вҠ—вӮң z' by
    obtain вҹЁN, z', hwвҹ© := h ((Algebra.TensorProduct.assoc в„Ө в„Ө в„Ө в„ҡ рқ“һ ZHat) z)
    refine вҹЁN, z', ?_вҹ©
    have hz : z = (Algebra.TensorProduct.assoc в„Ө в„Ө в„Ө в„ҡ рқ“һ ZHat).symm
        ((1 / N : в„ҡ) вҠ—вӮң[в„Ө] z') := by
      rw [вҶҗ hw, AlgEquiv.symm_apply_apply]
    rw [hz]
    have hmul : ((1 / N : в„ҡ) вҠ—вӮң[в„Ө] z' : в„ҡ вҠ—[в„Ө] рқ“һ^)
        = ((1 / N : в„ҡ) вҠ—вӮң (1 : рқ“һ^)) * ((1 : в„ҡ) вҠ—вӮң z') := by
      simp [Algebra.TensorProduct.tmul_mul_tmul]
    rw [hmul, map_mul]
    have hj1 : ((Algebra.TensorProduct.assoc в„Ө в„Ө в„Ө в„ҡ рқ“һ ZHat).symm
        ((1 / N : в„ҡ) вҠ—вӮң (1 : рқ“һ^)) : D^)
        = jвӮҒ (((вҶ‘вҶ‘N : в„ҡ)вҒ»В№ : в„ҡ) вҠ—вӮң[в„Ө] (1 : рқ“һ) : D) := by
      change _ = (((вҶ‘вҶ‘N : в„ҡ)вҒ»В№ вҠ—вӮң[в„Ө] (1 : рқ“һ)) вҠ—вӮң[в„Ө] (1 : ZHat) : D^)
      rw [one_div]
      rfl
    rw [hj1]
    rfl
  intro w
  induction w using TensorProduct.induction_on with
  | zero => exact вҹЁ1, 0, by simpвҹ©
  | tmul q x =>
    refine вҹЁвҹЁq.den, q.den_posвҹ©, q.num вҖў x, ?_вҹ©
    rw [show (1 / (вҶ‘вҶ‘вҹЁq.den, q.den_posвҹ© : в„•+) : в„ҡ) = (q.den : в„ҡ)вҒ»В№ from by simp [one_div]]
    rw [TensorProduct.tmul_smul, TensorProduct.smul_tmul', zsmul_eq_mul,
      вҶҗ Rat.mul_den_eq_num, mul_assoc,
      mul_inv_cancelвӮҖ (Nat.cast_ne_zero.mpr (Rat.den_ne_zero q)), mul_one]
  | add x y hx hy =>
    obtain вҹЁNвӮҒ, zвӮҒ, rflвҹ© := hx
    obtain вҹЁNвӮӮ, zвӮӮ, rflвҹ© := hy
    refine вҹЁNвӮҒ * NвӮӮ, (NвӮҒ : в„Ө) вҖў zвӮӮ + (NвӮӮ : в„Ө) вҖў zвӮҒ, ?_вҹ©
    simp only [TensorProduct.tmul_add,
      TensorProduct.tmul_smul, TensorProduct.smul_tmul']
    simp only [one_div, PNat.mul_coe, Nat.cast_mul, mul_inv_rev, zsmul_eq_mul, Int.cast_natCast,
      ne_eq, Nat.cast_eq_zero, PNat.ne_zero, not_false_eq_true, mul_inv_cancel_leftвӮҖ]
    rw [add_comm]
    congr
    simp [mul_comm]

/-- Rational scalars `jвӮҒ(q вҠ—вӮң 1)` are central in `D^`: they commute with the image of `jвӮӮ`.
This is because `q вҠ—вӮң 1 : D` lies in the image of `в„ҡ вҶ’ D = в„ҡ вҠ— рқ“һ`, and `в„ҡ` is the centre of the
rational quaternions. -/
lemma jвӮҒ_rat_mul_comm (q : в„ҡ) (z : рқ“һ^) :
    jвӮҒ ((q вҠ—вӮң (1 : рқ“һ) : D)) * jвӮӮ z = jвӮӮ z * jвӮҒ ((q вҠ—вӮң (1 : рқ“һ) : D)) := by
  -- Induct on z viewed as an element of рқ“һ вҠ—[в„Ө] ZHat
  induction z using TensorProduct.induction_on with
  | zero => simp
  | tmul o s =>
    -- Both sides equal `(q вҠ— o) вҠ— s` in `(в„ҡ вҠ— рқ“һ) вҠ— ZHat`
    change ((q вҠ—вӮң[в„Ө] (1 : рқ“һ)) вҠ—вӮң[в„Ө] (1 : ZHat) : (в„ҡ вҠ—[в„Ө] рқ“һ) вҠ—[в„Ө] ZHat) *
        ((Algebra.TensorProduct.assoc в„Ө в„Ө в„Ө в„ҡ рқ“һ ZHat).symm
          ((1 : в„ҡ) вҠ—вӮң[в„Ө] (o вҠ—вӮң[в„Ө] s))) =
        ((Algebra.TensorProduct.assoc в„Ө в„Ө в„Ө в„ҡ рқ“һ ZHat).symm
          ((1 : в„ҡ) вҠ—вӮң[в„Ө] (o вҠ—вӮң[в„Ө] s))) *
        ((q вҠ—вӮң[в„Ө] (1 : рқ“һ)) вҠ—вӮң[в„Ө] (1 : ZHat))
    have h1 : (Algebra.TensorProduct.assoc в„Ө в„Ө в„Ө в„ҡ рқ“һ ZHat).symm
        ((1 : в„ҡ) вҠ—вӮң[в„Ө] (o вҠ—вӮң[в„Ө] s)) =
        (((1 : в„ҡ) вҠ—вӮң[в„Ө] o) вҠ—вӮң[в„Ө] s : (в„ҡ вҠ—[в„Ө] рқ“һ) вҠ—[в„Ө] ZHat) := rfl
    rw [h1, Algebra.TensorProduct.tmul_mul_tmul, Algebra.TensorProduct.tmul_mul_tmul,
      Algebra.TensorProduct.tmul_mul_tmul, Algebra.TensorProduct.tmul_mul_tmul]
    simp [mul_one, one_mul, mul_comm]
  | add x y hx hy =>
    rw [map_add, mul_add, add_mul, hx, hy]

lemma completed_units (z : D^ЛЈ) : вҲғ (u : DЛЈ) (v : рқ“һ^ЛЈ), (z : D^) = jвӮҒ u * jвӮӮ v := sorry

end HurwitzRatHat
